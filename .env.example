# =============================================================================
# AirVibe Waveform Manager - Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values below.
#   cp .env.example .env

# --- Required ---

# Your fully qualified domain name (used by Caddy for auto-SSL and cert generation).
# Use "localhost" for local development.
DOMAIN=localhost

# --- Frontend ---

# Public URL for the frontend to reach the backend API and Socket.io.
# For local dev this can be omitted (defaults to http://localhost:4000).
# For production, set to your HTTPS domain:
# NEXT_PUBLIC_API_URL=https://mqtt.example.com

# --- MQTT (Optional) ---

# Mosquitto credentials (if you configure mosquitto.conf to require authentication)
# MQTT_USER=admin
# MQTT_PASS=password

# --- PostgreSQL (Optional - required for waveform data collection) ---

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=postgres
# POSTGRES_DB=airvibe
# POSTGRES_PORT=5432

# --- ThingPark DX API (Optional) ---
# Enables automatic Class A↔C device profile switching for FUOTA sessions.
# Without this, manually configure device profiles as Class C in ThingPark Device Manager before each FUOTA.
# THINGPARK_BASE_URL=https://community.thingpark.io
# THINGPARK_CLIENT_ID=community-api/your-email@example.com
# THINGPARK_CLIENT_SECRET=
# THINGPARK_CLASS_C_PROFILE=LORA/GenericC.1_ETSI_Rx2-SF9

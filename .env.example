# =============================================================================
# AirVibe Waveform Manager (On-Premise) — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values below.
#   cp .env.example .env

# --- Required ---

# Hostname or IP used by Caddy for TLS and CORS.
# For LAN access use "localhost" (dev) or your host's LAN IP / mDNS name.
# tls internal works without any public DNS record or internet access.
DOMAIN=localhost

# --- Frontend ---

# Public URL the browser uses to reach the backend API and Socket.io.
# Must be the HTTPS Caddy URL — do NOT use http://localhost:4000 here.
# Browsers block WebSocket upgrades from an HTTPS page to a plain HTTP URL.
NEXT_PUBLIC_API_URL=https://localhost
# For LAN / VPN access, set to your host's Caddy address instead:
# NEXT_PUBLIC_API_URL=https://airvibe.local
# NEXT_PUBLIC_API_URL=https://192.168.1.100

# --- MQTT (Optional) ---

# Mosquitto credentials — enable in mosquitto/config/mosquitto.conf if desired.
# MQTT_USER=admin
# MQTT_PASS=password

# --- PostgreSQL (Optional — defaults shown) ---

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=postgres
# POSTGRES_DB=airvibe
# POSTGRES_PORT=5432

# --- ChirpStack Integration ---
#
# CHIRPSTACK_API_URL: Internal URL of the ChirpStack server.
#   Default value is correct when using the included docker-compose.yml.
# CHIRPSTACK_API_URL=http://chirpstack:8080
#
# CHIRPSTACK_API_KEY: Generate this in the ChirpStack web UI after first boot.
#   Navigate to: API Keys → Create API Key → paste the token here.
#   Without this, FUOTA sessions work but Class A↔C switching must be done
#   manually in the ChirpStack UI before/after each firmware update.
# CHIRPSTACK_API_KEY=
#
# CHIRPSTACK_APPLICATION_ID: Numeric application ID in ChirpStack.
#   Create an application in ChirpStack UI → copy the ID from the URL.
#   Defaults to 1 (works if you only have one application).
# CHIRPSTACK_APPLICATION_ID=1

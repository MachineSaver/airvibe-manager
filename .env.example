# =============================================================================
# AirVibe Waveform Manager — Environment Configuration
# =============================================================================
# Copy: cp .env.example .env
#
# DEPLOYMENT MODES
# ─────────────────────────────────────────────────────────────────────────────
# ChirpStack (on-premise, default):
#   NETWORK_SERVER=chirpstack
#   COMPOSE_PROFILES=full
#   No other changes needed — docker compose up -d --build just works.
#
# Actility ThingPark (cloud):
#   NETWORK_SERVER=thingpark
#   COMPOSE_PROFILES=          (leave empty — ChirpStack services not needed)
#   DOMAIN=airvibe.yourcompany.com
#   NEXT_PUBLIC_API_URL=https://airvibe.yourcompany.com
#   MQTT_BROKER_URL stays at default — ThingPark connects TO our Mosquitto on
#   port 8883 (mTLS). Do NOT point MQTT_BROKER_URL at a ThingPark endpoint.
#   After starting the stack, generate TLS certificates on the Credentials
#   Manager tab and configure a ThingPark X IoT Flow MQTT connector pointing
#   at mqtts://airvibe.yourcompany.com:8883 with those certificates.
#
# On-premise, connect to an existing ChirpStack on the network:
#   COMPOSE_PROFILES=          (leave empty — don't start bundled ChirpStack)
#   MQTT_BROKER_URL=mqtt://192.168.1.100:1883
#   CHIRPSTACK_API_URL=http://192.168.1.100:8080
# =============================================================================

# --- Deployment mode ---------------------------------------------------------
#
# NETWORK_SERVER: selects the MQTT adapter and Caddyfile TLS mode.
#   chirpstack (default) — expects ChirpStack-format uplinks, converts
#                          downlinks to ChirpStack command format.
#   thingpark             — passthrough adapter; ThingPark publishes
#                          DevEUI_uplink JSON in canonical format already.
NETWORK_SERVER=chirpstack

# COMPOSE_PROFILES: set to "full" to start the bundled LoRaWAN infrastructure
# (ChirpStack, Redis, gateway bridge). Leave empty for ThingPark mode where
# only 5 services are needed (postgres, mqtt-broker, backend, frontend, caddy).
# Note: Mosquitto starts in all modes — it is not gated behind the "full" profile.
COMPOSE_PROFILES=full

# --- Domain ------------------------------------------------------------------
#
# Hostname Caddy listens on and uses for TLS.
#   ChirpStack / localhost: Caddy uses "tls internal" (LAN self-signed CA).
#     No public DNS record or internet access required.
#   ThingPark / public domain: Caddy requests a certificate from Let's Encrypt
#     automatically. Port 80+443 must be reachable from the internet.
DOMAIN=localhost

# --- Frontend API URL --------------------------------------------------------
#
# Browser-accessible URL for the backend API and Socket.io.
# IMPORTANT: this value is baked into the Next.js bundle at build time.
# After changing it, run "docker compose up -d --build" — a restart alone
# is not sufficient.
#
#   ChirpStack (localhost):          https://localhost
#   ThingPark (public domain):       https://airvibe.yourcompany.com
#   Local dev (bypassing Caddy):     http://localhost:4000
NEXT_PUBLIC_API_URL=https://localhost

# --- MQTT broker -------------------------------------------------------------
#
# URL the backend connects to for MQTT.
#   ChirpStack full profile: leave as-is — backend connects to bundled Mosquitto.
#   ChirpStack app-only:     mqtt://192.168.1.100:1883  (plant ChirpStack broker)
#   ThingPark:               leave as-is — backend connects to bundled Mosquitto
#                            on port 1883 internally. ThingPark connects TO our
#                            Mosquitto on port 8883 (mTLS) — not the other way around.
MQTT_BROKER_URL=mqtt://mqtt-broker:1883

# MQTT credentials — only needed for external brokers (ChirpStack app-only
# pointing at a password-protected broker). Leave blank for the bundled
# Mosquitto (used in both full and ThingPark modes).
# MQTT_USER=
# MQTT_PASS=

# --- PostgreSQL --------------------------------------------------------------
#
# AirVibe application database (device registry, waveform history, FUOTA sessions).
# Change POSTGRES_PASSWORD in production.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airvibe
# POSTGRES_PORT=5432

# --- ChirpStack API (optional — enables Class C auto-switch for FUOTA) -------
#
# CHIRPSTACK_API_URL: URL of the ChirpStack REST API.
#   Full profile default (http://chirpstack:8080) is correct as-is.
#   App-only mode: point at the plant ChirpStack box instead.
CHIRPSTACK_API_URL=http://chirpstack:8080

# CHIRPSTACK_API_KEY: generate in ChirpStack UI → API Keys → Create.
#   Without this, FUOTA works but Class A↔C switching must be done manually
#   in the ChirpStack UI before/after each firmware update session.
# CHIRPSTACK_API_KEY=

# CHIRPSTACK_APPLICATION_ID: numeric app ID from the ChirpStack UI URL.
#   Defaults to 1 (correct if you have only one application).
CHIRPSTACK_APPLICATION_ID=1

# --- ThingPark API (optional — enables Class C auto-switch for FUOTA) --------
#
# Required when NETWORK_SERVER=thingpark to enable automatic device profile
# switching (Class A → Class C) before each FUOTA session.
# Without these, FUOTA works but profile switching must be done manually in
# the ThingPark portal before and after each firmware update session.
#
# THINGPARK_BASE_URL: base URL of your ThingPark instance.
#   Community server default is correct for most users.
THINGPARK_BASE_URL=https://community.thingpark.io
#
# THINGPARK_CLIENT_ID / THINGPARK_CLIENT_SECRET: OAuth2 client credentials.
#   Generate in ThingPark portal → DX Admin → Applications → Add.
# THINGPARK_CLIENT_ID=
# THINGPARK_CLIENT_SECRET=
#
# THINGPARK_CLASS_C_PROFILE: device profile ID to apply before FUOTA.
#   Default is the EU868 Class C generic profile; change for other regions.
# THINGPARK_CLASS_C_PROFILE=LORA/GenericC.1_ETSI_Rx2-SF9

# --- FUOTA timing overrides (optional) ---------------------------------------
#
# FUOTA_BLOCK_INTERVAL_MS: delay between 49-byte blocks during transmission.
#   Default: 10000 (10 s). Reduce only if your LoRaWAN network supports it.
# FUOTA_BLOCK_INTERVAL_MS=10000

# FUOTA_SESSION_TIMEOUT_MS: maximum session lifetime before auto-abort.
#   Default: 259200000 (72 h).
# FUOTA_SESSION_TIMEOUT_MS=259200000
